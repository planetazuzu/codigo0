<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <!-- Fondo -->
  <rect width="1200" height="800" fill="#f8f9fa"/>
  
  <!-- Título -->
  <rect x="20" y="20" width="1160" height="70" fill="#dc3545" rx="8"/>
  <text x="600" y="65" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">RCP ADULTO - PASO A PASO VISUAL</text>
  
  <!-- Paso 1 -->
  <g>
    <rect x="40" y="120" width="260" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="170" cy="200" r="50" fill="#28a745" stroke="#1e7e34" stroke-width="3"/>
    <text x="170" y="210" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">1</text>
    <text x="170" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">SEGURIDAD</text>
    <text x="170" y="295" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Verificar escena</text>
    <text x="170" y="315" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">segura antes de</text>
    <text x="170" y="335" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">intervenir</text>
    <rect x="60" y="360" width="220" height="40" fill="#d4edda" rx="4"/>
    <text x="170" y="385" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#155724" text-anchor="middle">Protege primero tu vida</text>
  </g>
  
  <!-- Paso 2 -->
  <g>
    <rect x="320" y="120" width="260" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="450" cy="200" r="50" fill="#ffc107" stroke="#d39e00" stroke-width="3"/>
    <text x="450" y="210" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">2</text>
    <text x="450" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">CONSCIENCIA</text>
    <text x="450" y="295" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Sacudir hombros</text>
    <text x="450" y="315" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Gritar: "żEstás bien?"</text>
    <text x="450" y="335" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Si no responde ’</text>
    <rect x="340" y="360" width="220" height="40" fill="#fff3cd" rx="4"/>
    <text x="450" y="385" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#856404" text-anchor="middle">Actuar rápido es vital</text>
  </g>
  
  <!-- Paso 3 -->
  <g>
    <rect x="600" y="120" width="260" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="730" cy="200" r="50" fill="#dc3545" stroke="#c82333" stroke-width="3"/>
    <text x="730" y="210" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">3</text>
    <text x="730" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">LLAMAR 112</text>
    <text x="730" y="295" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Activar emergencias</text>
    <text x="730" y="315" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Pedir DESA</text>
    <text x="730" y="335" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Altavoz si estás solo</text>
    <rect x="620" y="360" width="220" height="40" fill="#f8d7da" rx="4"/>
    <text x="730" y="385" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#721c24" text-anchor="middle">NO esperes para llamar</text>
  </g>
  
  <!-- Paso 4 -->
  <g>
    <rect x="880" y="120" width="280" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="1020" cy="200" r="50" fill="#17a2b8" stroke="#117a8b" stroke-width="3"/>
    <text x="1020" y="210" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">4</text>
    <text x="1020" y="270" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">VÍA AÉREA</text>
    <text x="1020" y="295" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Frente-mentón</text>
    <text x="1020" y="315" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">VER-OÍR-SENTIR</text>
    <text x="1020" y="335" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Máximo 10 segundos</text>
    <rect x="900" y="360" width="240" height="40" fill="#d1ecf1" rx="4"/>
    <text x="1020" y="385" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#0c5460" text-anchor="middle">Gasping = No respira</text>
  </g>
  
  <!-- Paso 5 -->
  <g>
    <rect x="40" y="460" width="360" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="220" cy="540" r="50" fill="#dc3545" stroke="#c82333" stroke-width="3"/>
    <text x="220" y="550" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">5</text>
    <text x="220" y="610" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">30 COMPRESIONES</text>
    <text x="220" y="635" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Centro del tórax</text>
    <text x="220" y="655" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" 5-6 cm profundidad</text>
    <text x="220" y="675" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" 100-120 por minuto</text>
    <text x="220" y="695" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Descompresión completa</text>
    <rect x="60" y="715" width="320" height="30" fill="#f8d7da" rx="4"/>
    <text x="220" y="735" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#721c24" text-anchor="middle">Ritmo: "Stayin' Alive" - Bee Gees</text>
  </g>
  
  <!-- Paso 6 -->
  <g>
    <rect x="420" y="460" width="360" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="600" cy="540" r="50" fill="#17a2b8" stroke="#117a8b" stroke-width="3"/>
    <text x="600" y="550" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">6</text>
    <text x="600" y="610" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">2 VENTILACIONES</text>
    <text x="600" y="635" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Abrir vía aérea</text>
    <text x="600" y="655" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Sellar boca-boca</text>
    <text x="600" y="675" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" 1 segundo cada una</text>
    <text x="600" y="695" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Ver elevación torácica</text>
    <rect x="440" y="715" width="320" height="30" fill="#d1ecf1" rx="4"/>
    <text x="600" y="735" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#0c5460" text-anchor="middle">Si no puedes: SOLO compresiones</text>
  </g>
  
  <!-- Paso 7 -->
  <g>
    <rect x="800" y="460" width="360" height="300" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="980" cy="540" r="50" fill="#28a745" stroke="#1e7e34" stroke-width="3"/>
    <text x="980" y="550" font-family="Arial, sans-serif" font-size="36" font-weight="bold" fill="white" text-anchor="middle">7</text>
    <text x="980" y="610" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">CONTINUAR</text>
    <text x="980" y="635" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Repetir ciclos 30:2</text>
    <text x="980" y="660" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Hasta que:</text>
    <text x="980" y="680" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Llegue ayuda</text>
    <text x="980" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">" Respire normal</text>
    <rect x="820" y="720" width="320" height="30" fill="#d4edda" rx="4"/>
    <text x="980" y="740" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#155724" text-anchor="middle">Cambiar cada 2 min si hay ayuda</text>
  </g>
</svg>
