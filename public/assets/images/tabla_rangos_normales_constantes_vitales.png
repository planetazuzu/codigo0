<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="800" viewBox="0 0 1200 800">
  <!-- Fondo -->
  <rect width="1200" height="800" fill="#f8f9fa"/>
  
  <!-- Titulo -->
  <rect x="20" y="20" width="1160" height="70" fill="#28a745" rx="8"/>
  <text x="600" y="65" font-family="Arial, sans-serif" font-size="32" font-weight="bold" fill="white" text-anchor="middle">CONSTANTES VITALES - RANGOS NORMALES</text>
  
  <!-- Tabla principal -->
  <g>
    <!-- Encabezados -->
    <rect x="80" y="120" width="220" height="60" fill="#6c757d" rx="4"/>
    <text x="190" y="155" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">CONSTANTE</text>
    
    <rect x="310" y="120" width="200" height="60" fill="#17a2b8" rx="4"/>
    <text x="410" y="155" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">ADULTO</text>
    
    <rect x="520" y="120" width="200" height="60" fill="#fd7e14" rx="4"/>
    <text x="620" y="155" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">NINO</text>
    <text x="620" y="170" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle">(1-8 anos)</text>
    
    <rect x="730" y="120" width="200" height="60" fill="#6610f2" rx="4"/>
    <text x="830" y="155" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">LACTANTE</text>
    <text x="830" y="170" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle">(< 1 ano)</text>
    
    <rect x="940" y="120" width="180" height="60" fill="#20c997" rx="4"/>
    <text x="1030" y="155" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="white" text-anchor="middle">UNIDAD</text>
    
    <!-- Fila 1: FC -->
    <rect x="80" y="190" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="215" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">FREC. CARDIACA</text>
    <text x="190" y="235" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(FC)</text>
    
    <rect x="310" y="190" width="200" height="70" fill="#e7f3ff" stroke="#17a2b8" stroke-width="1"/>
    <text x="410" y="230" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#0066cc" text-anchor="middle">60-100</text>
    
    <rect x="520" y="190" width="200" height="70" fill="#fff5e6" stroke="#fd7e14" stroke-width="1"/>
    <text x="620" y="230" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#d65d0e" text-anchor="middle">70-120</text>
    
    <rect x="730" y="190" width="200" height="70" fill="#f3e5ff" stroke="#6610f2" stroke-width="1"/>
    <text x="830" y="230" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#6610f2" text-anchor="middle">100-160</text>
    
    <rect x="940" y="190" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="230" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">lpm</text>
    
    <!-- Fila 2: FR -->
    <rect x="80" y="270" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="295" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">FREC. RESPIRATORIA</text>
    <text x="190" y="315" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(FR)</text>
    
    <rect x="310" y="270" width="200" height="70" fill="#e7f3ff" stroke="#17a2b8" stroke-width="1"/>
    <text x="410" y="310" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#0066cc" text-anchor="middle">12-20</text>
    
    <rect x="520" y="270" width="200" height="70" fill="#fff5e6" stroke="#fd7e14" stroke-width="1"/>
    <text x="620" y="310" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#d65d0e" text-anchor="middle">20-30</text>
    
    <rect x="730" y="270" width="200" height="70" fill="#f3e5ff" stroke="#6610f2" stroke-width="1"/>
    <text x="830" y="310" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#6610f2" text-anchor="middle">30-60</text>
    
    <rect x="940" y="270" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="310" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">rpm</text>
    
    <!-- Fila 3: TAS -->
    <rect x="80" y="350" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="375" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">TA SISTOLICA</text>
    <text x="190" y="395" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(TAS)</text>
    
    <rect x="310" y="350" width="200" height="70" fill="#e7f3ff" stroke="#17a2b8" stroke-width="1"/>
    <text x="410" y="390" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#0066cc" text-anchor="middle">90-140</text>
    
    <rect x="520" y="350" width="200" height="70" fill="#fff5e6" stroke="#fd7e14" stroke-width="1"/>
    <text x="620" y="390" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#d65d0e" text-anchor="middle">80-120</text>
    
    <rect x="730" y="350" width="200" height="70" fill="#f3e5ff" stroke="#6610f2" stroke-width="1"/>
    <text x="830" y="390" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#6610f2" text-anchor="middle">70-90</text>
    
    <rect x="940" y="350" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="390" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">mmHg</text>
    
    <!-- Fila 4: SpO2 -->
    <rect x="80" y="430" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="455" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">SATURACION O2</text>
    <text x="190" y="475" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(SpO2)</text>
    
    <rect x="310" y="430" width="200" height="70" fill="#d4edda" stroke="#28a745" stroke-width="2"/>
    <text x="410" y="470" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#155724" text-anchor="middle">&gt; 94%</text>
    
    <rect x="520" y="430" width="200" height="70" fill="#d4edda" stroke="#28a745" stroke-width="2"/>
    <text x="620" y="470" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#155724" text-anchor="middle">&gt; 94%</text>
    
    <rect x="730" y="430" width="200" height="70" fill="#d4edda" stroke="#28a745" stroke-width="2"/>
    <text x="830" y="470" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#155724" text-anchor="middle">&gt; 94%</text>
    
    <rect x="940" y="430" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="470" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">%</text>
    
    <!-- Fila 5: Temperatura -->
    <rect x="80" y="510" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="535" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">TEMPERATURA</text>
    <text x="190" y="555" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(Temp)</text>
    
    <rect x="310" y="510" width="200" height="70" fill="#e7f3ff" stroke="#17a2b8" stroke-width="1"/>
    <text x="410" y="550" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#0066cc" text-anchor="middle">36.0-37.5</text>
    
    <rect x="520" y="510" width="200" height="70" fill="#fff5e6" stroke="#fd7e14" stroke-width="1"/>
    <text x="620" y="550" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#d65d0e" text-anchor="middle">36.0-37.5</text>
    
    <rect x="730" y="510" width="200" height="70" fill="#f3e5ff" stroke="#6610f2" stroke-width="1"/>
    <text x="830" y="550" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#6610f2" text-anchor="middle">36.5-37.5</text>
    
    <rect x="940" y="510" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="550" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">C</text>
    
    <!-- Fila 6: Glasgow -->
    <rect x="80" y="590" width="220" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="190" y="615" font-family="Arial, sans-serif" font-size="16" font-weight="bold" text-anchor="middle">GLASGOW</text>
    <text x="190" y="635" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">(GCS)</text>
    
    <rect x="310" y="590" width="200" height="70" fill="#d4edda" stroke="#28a745" stroke-width="2"/>
    <text x="410" y="630" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#155724" text-anchor="middle">15</text>
    
    <rect x="520" y="590" width="200" height="70" fill="#d4edda" stroke="#28a745" stroke-width="2"/>
    <text x="620" y="630" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#155724" text-anchor="middle">15</text>
    
    <rect x="730" y="590" width="200" height="70" fill="#dee2e6" stroke="#6c757d" stroke-width="2"/>
    <text x="830" y="630" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">N/A</text>
    
    <rect x="940" y="590" width="180" height="70" fill="white" stroke="#dee2e6" stroke-width="2"/>
    <text x="1030" y="630" font-family="Arial, sans-serif" font-size="16" text-anchor="middle">puntos</text>
  </g>
  
  <!-- Interpretacion codificada por colores -->
  <text x="600" y="700" font-family="Arial, sans-serif" font-size="20" font-weight="bold" text-anchor="middle">INTERPRETACION RAPIDA (SEMAFORO)</text>
  
  <g>
    <!-- Verde: Normal -->
    <rect x="100" y="720" width="310" height="60" fill="#d4edda" stroke="#28a745" stroke-width="3" rx="6"/>
    <circle cx="140" cy="750" r="20" fill="#28a745"/>
    <text x="200" y="745" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#155724">NORMAL</text>
    <text x="200" y="765" font-family="Arial, sans-serif" font-size="13" fill="#155724">Paciente estable</text>
    
    <!-- Amarillo: Alerta -->
    <rect x="440" y="720" width="310" height="60" fill="#fff3cd" stroke="#ffc107" stroke-width="3" rx="6"/>
    <circle cx="480" cy="750" r="20" fill="#ffc107"/>
    <text x="540" y="745" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#856404">ALERTA</text>
    <text x="540" y="765" font-family="Arial, sans-serif" font-size="13" fill="#856404">Desviacion leve, vigilar</text>
    
    <!-- Rojo: Critico -->
    <rect x="780" y="720" width="310" height="60" fill="#f8d7da" stroke="#dc3545" stroke-width="3" rx="6"/>
    <circle cx="820" cy="750" r="20" fill="#dc3545"/>
    <text x="880" y="745" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#721c24">CRITICO</text>
    <text x="880" y="765" font-family="Arial, sans-serif" font-size="13" fill="#721c24">Actuar inmediatamente</text>
  </g>
  
  <!-- Valores criticos -->
  <rect x="50" y="800" width="1100" height="0" fill="none"/>
</svg>
