<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="900" viewBox="0 0 1200 900">
  <!-- Fondo -->
  <rect width="1200" height="900" fill="#f8f9fa"/>
  
  <!-- Titulo -->
  <rect x="20" y="20" width="1160" height="70" fill="#dc3545" rx="8"/>
  <text x="600" y="65" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">RCP PEDIATRICA (1-8 ANOS) - DIFERENCIAS CON ADULTO</text>
  
  <!-- Diferencias clave -->
  <rect x="50" y="110" width="1100" height="80" fill="#6610f2" rx="8"/>
  <text x="600" y="140" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="white" text-anchor="middle">CAMBIOS RESPECTO A RCP ADULTO</text>
  <text x="600" y="165" font-family="Arial, sans-serif" font-size="16" fill="white" text-anchor="middle">Profundidad 5 cm (1/3 del torax) | 1 o 2 manos segun tamano | Ratio 15:2 si 2 reanimadores, 30:2 si 1 solo</text>
  
  <!-- Comparativa 3 columnas -->
  
  <!-- Compresiones -->
  <g>
    <rect x="40" y="220" width="360" height="320" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="220" cy="270" r="40" fill="#dc3545"/>
    <text x="220" y="280" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">1</text>
    
    <text x="220" y="340" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">COMPRESIONES</text>
    
    <text x="220" y="375" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Profundidad: 5 cm</text>
    <text x="220" y="400" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">(1/3 del torax)</text>
    <text x="220" y="430" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Frecuencia: 100-120/min</text>
    <text x="220" y="455" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">(igual que adulto)</text>
    <text x="220" y="485" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Tecnica: 1 o 2 manos</text>
    <text x="220" y="510" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">segun tamano del nino</text>
    
    <rect x="60" y="470" width="320" height="60" fill="#fff3cd" rx="4"/>
    <text x="220" y="495" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#856404" text-anchor="middle">Nino pequeno: 1 mano</text>
    <text x="220" y="513" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#856404" text-anchor="middle">Nino grande: 2 manos</text>
  </g>
  
  <!-- Ventilaciones -->
  <g>
    <rect x="420" y="220" width="360" height="320" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="600" cy="270" r="40" fill="#17a2b8"/>
    <text x="600" y="280" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">2</text>
    
    <text x="600" y="340" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">VENTILACIONES</text>
    
    <text x="600" y="375" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Volumen: MAS SUAVE</text>
    <text x="600" y="400" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">que adulto</text>
    <text x="600" y="430" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Duracion: 1 segundo</text>
    <text x="600" y="455" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">cada una</text>
    <text x="600" y="485" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Ver elevacion toracica</text>
    <text x="600" y="510" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">SUAVE (no forzar)</text>
    
    <rect x="440" y="470" width="320" height="60" fill="#f8d7da" rx="4"/>
    <text x="600" y="495" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#721c24" text-anchor="middle">Evitar hiperventilacion</text>
    <text x="600" y="513" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#721c24" text-anchor="middle">(causa gastrico)</text>
  </g>
  
  <!-- Ratio -->
  <g>
    <rect x="800" y="220" width="360" height="320" fill="white" stroke="#dee2e6" stroke-width="2" rx="8"/>
    <circle cx="980" cy="270" r="40" fill="#28a745"/>
    <text x="980" y="280" font-family="Arial, sans-serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">3</text>
    
    <text x="980" y="340" font-family="Arial, sans-serif" font-size="18" font-weight="bold" text-anchor="middle">RATIO</text>
    
    <text x="980" y="375" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">1 reanimador: 30:2</text>
    <text x="980" y="400" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">(igual que adulto)</text>
    
    <text x="980" y="435" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">2 reanimadores: 15:2</text>
    <text x="980" y="460" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">(DIFERENTE adulto)</text>
    
    <text x="980" y="495" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">Objetivo: Ventilar mas</text>
    <text x="980" y="520" font-family="Arial, sans-serif" font-size="15" text-anchor="middle">en pediatria</text>
    
    <rect x="820" y="470" width="320" height="60" fill="#d4edda" rx="4"/>
    <text x="980" y="495" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#155724" text-anchor="middle">Paradas pediatricas</text>
    <text x="980" y="513" font-family="Arial, sans-serif" font-size="13" font-weight="bold" fill="#155724" text-anchor="middle">suelen ser respiratorias</text>
  </g>
  
  <!-- Secuencia visual simplificada -->
  <rect x="50" y="560" width="1100" height="160" fill="#e7f3ff" stroke="#0066cc" stroke-width="2" rx="8"/>
  <text x="600" y="595" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="#0066cc" text-anchor="middle">SECUENCIA COMPLETA</text>
  
  <g>
    <circle cx="150" cy="650" r="35" fill="#ffc107"/>
    <text x="150" y="660" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#000" text-anchor="middle">1</text>
    <text x="150" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Seguridad</text>
  </g>
  
  <text x="230" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="300" cy="650" r="35" fill="#ffc107"/>
    <text x="300" y="660" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="#000" text-anchor="middle">2</text>
    <text x="300" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Consciencia</text>
  </g>
  
  <text x="380" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="450" cy="650" r="35" fill="#dc3545"/>
    <text x="450" y="660" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">3</text>
    <text x="450" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">112 + DESA</text>
  </g>
  
  <text x="530" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="600" cy="650" r="35" fill="#17a2b8"/>
    <text x="600" y="660" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">4</text>
    <text x="600" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Via aerea</text>
  </g>
  
  <text x="680" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="750" cy="650" r="35" fill="#dc3545"/>
    <text x="750" y="655" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="white" text-anchor="middle">15</text>
    <text x="750" y="670" font-family="Arial, sans-serif" font-size="12" fill="white" text-anchor="middle">o 30</text>
    <text x="750" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Compresiones</text>
  </g>
  
  <text x="830" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="900" cy="650" r="35" fill="#17a2b8"/>
    <text x="900" y="660" font-family="Arial, sans-serif" font-size="24" font-weight="bold" fill="white" text-anchor="middle">2</text>
    <text x="900" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Ventilaciones</text>
  </g>
  
  <text x="980" y="655" font-family="Arial, sans-serif" font-size="24" fill="#999">ĺ</text>
  
  <g>
    <circle cx="1050" cy="650" r="35" fill="#28a745"/>
    <text x="1050" y="665" font-family="Arial, sans-serif" font-size="20" font-weight="bold" fill="white" text-anchor="middle"></text>
    <text x="1050" y="700" font-family="Arial, sans-serif" font-size="14" text-anchor="middle">Repetir</text>
  </g>
  
  <!-- Notas criticas -->
  <rect x="50" y="740" width="540" height="130" fill="#fff3cd" rx="8" stroke="#ffc107" stroke-width="2"/>
  <text x="320" y="770" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#856404" text-anchor="middle">PUNTOS CLAVE PEDIATRIA</text>
  <text x="320" y="795" font-family="Arial, sans-serif" font-size="14" fill="#856404" text-anchor="middle">5 ventilaciones iniciales ANTES de compresiones</text>
  <text x="320" y="815" font-family="Arial, sans-serif" font-size="14" fill="#856404" text-anchor="middle">(paradas pediatricas suelen ser respiratorias)</text>
  <text x="320" y="840" font-family="Arial, sans-serif" font-size="14" fill="#856404" text-anchor="middle">Ventilaciones MAS importantes que en adulto</text>
  <text x="320" y="860" font-family="Arial, sans-serif" font-size="14" fill="#856404" text-anchor="middle">NO ventilar con fuerza (riesgo distension gastrica)</text>
  
  <!-- Edad y tecnica -->
  <rect x="610" y="740" width="540" height="130" fill="#d1ecf1" rx="8" stroke="#17a2b8" stroke-width="2"/>
  <text x="880" y="770" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#0c5460" text-anchor="middle">SEGUN EDAD Y TAMANO</text>
  <text x="880" y="795" font-family="Arial, sans-serif" font-size="14" fill="#0c5460" text-anchor="middle">1-3 anos (pequeno): 1 MANO</text>
  <text x="880" y="815" font-family="Arial, sans-serif" font-size="14" fill="#0c5460" text-anchor="middle">4-8 anos (grande): 2 MANOS como adulto</text>
  <text x="880" y="840" font-family="Arial, sans-serif" font-size="14" fill="#0c5460" text-anchor="middle">Si hay 2 reanimadores: ratio 15:2</text>
  <text x="880" y="860" font-family="Arial, sans-serif" font-size="14" fill="#0c5460" text-anchor="middle">Si estas solo: ratio 30:2 (como adulto)</text>
</svg>
